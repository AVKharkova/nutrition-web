# Скопируй этот файл в .env и заполни значениями из Supabase: Settings -> API
VITE_SUPABASE_URL=https://ВАШ_ПРОЕКТ.supabase.co
VITE_SUPABASE_ANON_KEY=ВАШ_ANON_KEY

# URL вебхука n8n из воркфлоу "WF-8 Web Backend" (Production URL узла Webhook)
VITE_N8N_WEB_API=https://ВАШ_N8N/webhook/web-api

# Юзернейм бота для Telegram Login Widget (без @)
VITE_TG_BOT=netkann_nutritionbot
